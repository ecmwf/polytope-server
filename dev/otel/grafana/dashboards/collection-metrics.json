{
  "uid": "polytope-collection-stats",
  "title": "Polytope Collection Metrics",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "10s",
  "tags": [
    "polytope",
    "collection",
    "metrics"
  ],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Accepted Collection Requests per Minute",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (route_handle)(rate(polytope_broker_collection_requests_accepted_total_total{route_handle=~\"$collection\"}[5m])) * 60",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "legendFormat": "{{route_handle}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Finished Collection Outcomes per Minute",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 45,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (route_handle, outcome)(rate(polytope_broker_collection_requests_finished_total_total{route_handle=~\"$collection\"}[5m])) * 60",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "legendFormat": "{{route_handle}} {{outcome}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Success/Redirect Share by Collection",
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 12,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (route_handle)(rate(polytope_broker_collection_requests_finished_total_total{route_handle=~\"$collection\",outcome=~\"success|redirect\"}[5m])) / sum by (route_handle)(rate(polytope_broker_collection_requests_finished_total_total{route_handle=~\"$collection\"}[5m])) * 100",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "legendFormat": "{{route_handle}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Collection Latency Percentiles",
      "gridPos": {
        "x": 12,
        "y": 7,
        "w": 12,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, route_handle)(rate(polytope_broker_collection_request_duration_seconds_bucket{route_handle=~\"$collection\"}[5m])))",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "legendFormat": "{{route_handle}} p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, route_handle)(rate(polytope_broker_collection_request_duration_seconds_bucket{route_handle=~\"$collection\"}[5m])))",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "legendFormat": "{{route_handle}} p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, route_handle)(rate(polytope_broker_collection_request_duration_seconds_bucket{route_handle=~\"$collection\"}[5m])))",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "legendFormat": "{{route_handle}} p99"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Accepted Requests in Window",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(polytope_broker_collection_requests_accepted_total_total{route_handle=~\"$collection\"}[$__range]))",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Success/Redirect Requests in Window",
      "gridPos": {
        "x": 6,
        "y": 14,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(polytope_broker_collection_requests_finished_total_total{route_handle=~\"$collection\",outcome=~\"success|redirect\"}[$__range]))",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Failed/Error Requests in Window",
      "gridPos": {
        "x": 12,
        "y": 14,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(polytope_broker_collection_requests_finished_total_total{route_handle=~\"$collection\",outcome=~\"failed|error\"}[$__range]))",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Avg Request Duration, Selected Collections",
      "gridPos": {
        "x": 18,
        "y": 14,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(polytope_broker_collection_request_duration_seconds_sum{route_handle=~\"$collection\"}[$__range])) / sum(rate(polytope_broker_collection_request_duration_seconds_count{route_handle=~\"$collection\"}[$__range])) * 1000",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "collection",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(polytope_broker_collection_requests_accepted_total_total, route_handle)",
        "refresh": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": ".*"
        },
        "sort": 1
      }
    ]
  },
  "annotations": {
    "list": []
  }
}
