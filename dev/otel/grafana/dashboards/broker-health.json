{
  "uid": "polytope-brokers",
  "title": "Polytope Broker Health",
  "tags": [
    "polytope",
    "bits",
    "infrastructure"
  ],
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Brokers Active",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "count(count by (instance)(polytope_requests_finished_total))",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 2,
      "title": "Requests in Window",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(polytope_requests_accepted_total[$__range]))",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 3,
      "title": "Throughput by Broker (req/min)",
      "type": "timeseries",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 10,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (instance)(rate(polytope_requests_accepted_total[5m])) * 60",
          "legendFormat": "{{instance}}",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Success Rate by Broker (%)",
      "type": "timeseries",
      "gridPos": {
        "x": 14,
        "y": 0,
        "w": 10,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (instance)(rate(polytope_requests_finished_total{outcome=\"success\"}[5m])) / sum by (instance)(rate(polytope_requests_finished_total[5m])) * 100",
          "legendFormat": "{{instance}}",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 80,
                "color": "orange"
              },
              {
                "value": 95,
                "color": "green"
              }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Per-Broker Details",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 6,
      "title": "Outcomes by Broker (rate/min)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (instance, outcome)(rate(polytope_requests_finished_total[5m])) * 60",
          "legendFormat": "{{instance}} \u2014 {{outcome}}",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*success"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*error"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*failed"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 7,
      "title": "p95 Duration by Broker",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 9,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, instance)(rate(polytope_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{instance}}",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Per-Broker Collection Mix",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 17,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 9,
      "title": "Collection Throughput by Broker",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 18,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum by (instance, route_handle)(rate(polytope_collection_requests_accepted_total[5m])) * 60",
          "legendFormat": "{{instance}} / {{route_handle}}",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Collection Success Rate by Broker",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 18,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum by (instance, route_handle)(rate(polytope_collection_requests_finished_total{outcome=\"success\"}[5m])) / sum by (instance, route_handle)(rate(polytope_collection_requests_finished_total[5m])) * 100",
          "legendFormat": "{{instance}} / {{route_handle}}",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      }
    }
  ]
}