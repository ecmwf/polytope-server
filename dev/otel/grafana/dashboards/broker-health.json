{
  "title": "Polytope Broker Health",
  "tags": [
    "polytope",
    "bits",
    "infrastructure"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Brokers Seen",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "count(count by (instance)(polytope_broker_requests_finished_total_total))",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 2,
      "title": "Requests Accepted in Dashboard Range",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(polytope_broker_requests_accepted_total_total[$__range]))",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 3,
      "title": "Accepted Request Throughput by Broker",
      "type": "timeseries",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 10,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (instance)(rate(polytope_broker_requests_accepted_total_total[5m])) * 60",
          "legendFormat": "{{instance}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Success/Redirect Percentage by Broker",
      "gridPos": {
        "x": 14,
        "y": 0,
        "w": 10,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (instance)(rate(polytope_broker_requests_finished_total_total{outcome=~\"success|redirect\"}[5m])) / sum by (instance)(rate(polytope_broker_requests_finished_total_total[5m])) * 100",
          "legendFormat": "{{instance}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        }
      }
    },
    {
      "id": 5,
      "title": "Per-Broker Details",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 6,
      "title": "Finished Requests by Outcome and Broker",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (instance, outcome)(rate(polytope_broker_requests_finished_total_total[5m])) * 60",
          "legendFormat": "{{instance}} \u2014 {{outcome}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": {
            "fillOpacity": 45,
            "lineWidth": 1,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "drawStyle": "line"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Request Latency Percentiles by Broker",
      "gridPos": {
        "x": 12,
        "y": 9,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, instance)(rate(polytope_broker_request_duration_seconds_bucket[5m])))",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "legendFormat": "{{instance}} p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, instance)(rate(polytope_broker_request_duration_seconds_bucket[5m])))",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "legendFormat": "{{instance}} p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, instance)(rate(polytope_broker_request_duration_seconds_bucket[5m])))",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "legendFormat": "{{instance}} p99"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      }
    ]
  },
  "version": 4
}
