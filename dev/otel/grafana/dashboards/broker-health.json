{
  "title": "Polytope Broker Health",
  "tags": [
    "polytope",
    "bits",
    "infrastructure"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Brokers Active",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "count(count by (service_instance_id)(polytope_broker_requests_finished_total_total))",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 2,
      "title": "Requests in Window",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(polytope_broker_requests_accepted_total_total[$__range]))",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 3,
      "title": "Throughput by Broker (req/min)",
      "type": "timeseries",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 10,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (service_instance_id)(rate(polytope_broker_requests_accepted_total_total[5m])) * 60",
          "legendFormat": "{{service_instance_id}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Success Rate by Broker (%)",
      "type": "timeseries",
      "gridPos": {
        "x": 14,
        "y": 0,
        "w": 10,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (service_instance_id)(rate(polytope_broker_requests_finished_total_total{outcome=\"success\"}[5m])) / sum by (service_instance_id)(rate(polytope_broker_requests_finished_total_total[5m])) * 100",
          "legendFormat": "{{service_instance_id}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 80,
                "color": "orange"
              },
              {
                "value": 95,
                "color": "green"
              }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Per-Broker Details",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 6,
      "title": "Outcomes by Broker (rate/min)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (service_instance_id, outcome)(rate(polytope_broker_requests_finished_total_total[5m])) * 60",
          "legendFormat": "{{service_instance_id}} \u2014 {{outcome}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 7,
      "title": "p95 Duration by Broker",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 9,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, service_instance_id)(rate(polytope_broker_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{service_instance_id}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Per-Broker Collection Mix",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 17,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 9,
      "title": "Collection Throughput by Broker",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 18,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum by (service_instance_id, route_handle)(rate(polytope_broker_collection_requests_accepted_total_total[5m])) * 60",
          "legendFormat": "{{service_instance_id}} / {{route_handle}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Collection Success Rate by Broker",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 18,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum by (service_instance_id, route_handle)(rate(polytope_broker_collection_requests_finished_total_total{outcome=\"success\"}[5m])) / sum by (service_instance_id, route_handle)(rate(polytope_broker_collection_requests_finished_total_total[5m])) * 100",
          "legendFormat": "{{service_instance_id}} / {{route_handle}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      }
    ]
  }
}