{
  "uid": "polytope-raw-metrics",
  "title": "Polytope Raw Metrics (Debug)",
  "tags": ["polytope", "debug"],
  "description": "Raw counter and histogram values for debugging. Use the Overview dashboard for operational monitoring.",
  "graphTooltip": 1,
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Broker Request Counters (raw)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "expr": "polytope_broker_requests_accepted_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "legendFormat": "accepted {{service_instance_id}}"
        },
        {
          "expr": "polytope_broker_requests_finished_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "legendFormat": "finished {{outcome}} {{service_instance_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
