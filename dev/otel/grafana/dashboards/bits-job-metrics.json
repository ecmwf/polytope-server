{
  "title": "Polytope Broker Metrics",
  "tags": [
    "polytope",
    "bits"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Requests Accepted (rate/min)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum(rate(polytope_broker_requests_accepted_total_total[5m])) * 60",
          "legendFormat": "accepted",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Request Outcomes (rate/min)",
      "type": "timeseries",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum by (outcome)(rate(polytope_broker_requests_finished_total_total[5m])) * 60",
          "legendFormat": "{{outcome}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "success"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "error"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "failed"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "overloaded"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "yellow",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 3,
      "title": "Request Duration",
      "type": "timeseries",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le)(rate(polytope_broker_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le)(rate(polytope_broker_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le)(rate(polytope_broker_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Accepted",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(polytope_broker_requests_accepted_total_total[$__range]))",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 5,
      "title": "Success",
      "type": "stat",
      "gridPos": {
        "x": 4,
        "y": 7,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(polytope_broker_requests_finished_total_total{outcome=\"success\"}[$__range]))",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "fixedColor": "green",
            "mode": "fixed"
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 6,
      "title": "Errors",
      "type": "stat",
      "gridPos": {
        "x": 8,
        "y": 7,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(polytope_broker_requests_finished_total_total{outcome=\"error\"}[$__range]))",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "fixedColor": "orange",
            "mode": "fixed"
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 7,
      "title": "Failed",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 7,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(polytope_broker_requests_finished_total_total{outcome=\"failed\"}[$__range]))",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "fixedColor": "red",
            "mode": "fixed"
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 8,
      "title": "Avg Duration (ms)",
      "type": "stat",
      "gridPos": {
        "x": 16,
        "y": 7,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(polytope_broker_request_duration_seconds_sum) / sum(polytope_broker_request_duration_seconds_count) * 1000",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 9,
      "title": "Success Rate",
      "type": "stat",
      "gridPos": {
        "x": 20,
        "y": 7,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(polytope_broker_requests_finished_total_total{outcome=\"success\"}[5m])) / sum(rate(polytope_broker_requests_finished_total_total[5m])) * 100",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 80,
                "color": "orange"
              },
              {
                "value": 95,
                "color": "green"
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 10,
      "title": "Per-Collection",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
