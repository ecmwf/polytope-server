        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum by (service_instance_id)(rate(polytope_broker_requests_finished_total_total{outcome=\"success\"}[5m])) / sum by (service_instance_id)(rate(polytope_broker_requests_finished_total_total[5m])) * 100",
