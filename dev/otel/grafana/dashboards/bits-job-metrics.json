{
  "title": "Polytope Broker Metrics",
  "tags": [
    "polytope",
    "bits"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Accepted Requests per Minute",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum(rate(polytope_broker_requests_accepted_total_total[5m])) * 60",
          "legendFormat": "accepted",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Finished Request Outcomes per Minute",
      "type": "timeseries",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum by (outcome)(rate(polytope_broker_requests_finished_total_total[5m])) * 60",
          "legendFormat": "{{outcome}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": {
            "fillOpacity": 45,
            "lineWidth": 1,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "drawStyle": "line"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "success"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "error"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "failed"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "overloaded"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "yellow",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Request Latency Percentiles",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 8,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le)(rate(polytope_broker_request_duration_seconds_bucket[5m])))",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le)(rate(polytope_broker_request_duration_seconds_bucket[5m])))",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le)(rate(polytope_broker_request_duration_seconds_bucket[5m])))",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "legendFormat": "p99"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        }
      }
    },
    {
      "id": 4,
      "title": "Accepted Requests in Range",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(polytope_broker_requests_accepted_total_total[$__range]))",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Successful/Redirected Requests in Range",
      "gridPos": {
        "x": 4,
        "y": 7,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(polytope_broker_requests_finished_total_total{outcome=~\"success|redirect\"}[$__range]))",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 6,
      "title": "Error Requests in Range",
      "type": "stat",
      "gridPos": {
        "x": 8,
        "y": 7,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(polytope_broker_requests_finished_total_total{outcome=\"error\"}[$__range]))",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "fixedColor": "orange",
            "mode": "fixed"
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Failed or Error Requests in Range",
      "gridPos": {
        "x": 12,
        "y": 7,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(polytope_broker_requests_finished_total_total{outcome=~\"failed|error\"}[$__range]))",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 8,
      "title": "Avg Request Duration in Range",
      "type": "stat",
      "gridPos": {
        "x": 16,
        "y": 7,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(polytope_broker_request_duration_seconds_sum[$__range])) / sum(rate(polytope_broker_request_duration_seconds_count[$__range])) * 1000",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 15,
      "title": "Broker Health",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 16,
      "title": "Accepted Requests by Broker per Minute",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum by (instance)(rate(polytope_broker_requests_accepted_total_total[5m])) * 60",
          "legendFormat": "{{instance}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      }
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "Success/Redirect Percentage by Broker",
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (instance)(rate(polytope_broker_requests_finished_total_total{outcome=~\"success|redirect\"}[5m])) / sum by (instance)(rate(polytope_broker_requests_finished_total_total[5m])) * 100",
          "legendFormat": "{{instance}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      }
    ]
  },
  "version": 4
}
