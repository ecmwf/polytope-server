      "id": 16,
      "title": "Throughput by Broker (req/min)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 27,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum by (service_instance_id)(rate(polytope_broker_requests_accepted_total_total[5m])) * 60",
          "legendFormat": "{{service_instance_id}}",
          "datasource": {
            "type": "prometheus",
