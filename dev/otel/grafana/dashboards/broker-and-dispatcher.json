{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Datasource",
      "description": "Prometheus datasource for Polytope metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "uid": "polytope-broker-dispatcher-merged",
  "title": "Polytope Broker & Dispatcher",
  "description": "Broker request handling and dispatcher queue metrics. Drill down by broker instance.",
  "tags": [
    "polytope",
    "broker",
    "dispatcher",
    "tier:drilldown"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "graphTooltip": 1,
  "editable": true,
  "schemaVersion": 39,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "links": [
    {
      "title": "\u2190 Overview",
      "type": "link",
      "icon": "arrow-left",
      "url": "/d/polytope-overview/polytope-overview?${__url_time_range}&${__all_variables}",
      "targetBlank": false
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "label": "Datasource",
        "current": {
          "selected": true,
          "text": "Thanos CCI1",
          "value": "Thanos CCI1"
        },
        "hide": 0
      },
      {
        "name": "cluster",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(polytope_broker_requests_accepted_total, cluster)",
        "label": "Cluster",
        "hide": 0,
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "sort": 1,
        "current": {}
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(polytope_broker_requests_accepted_total{cluster=~\"$cluster\"}, namespace)",
        "label": "Namespace",
        "hide": 0,
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "sort": 1,
        "current": {}
      },
      {
        "name": "service_instance_id",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(polytope_broker_requests_accepted_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}, service_instance_id)",
        "label": "Broker Instance",
        "hide": 0,
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "sort": 1,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Brokers Seen",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "count(count by (service_instance_id)(polytope_broker_requests_finished_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}))",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 2,
      "title": "Accepted in Range",
      "type": "stat",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(polytope_broker_requests_accepted_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__range]))",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 3,
      "title": "Success/Redirect in Range",
      "type": "stat",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(polytope_broker_requests_finished_total{cluster=~\"$cluster\", namespace=~\"$namespace\", outcome=~\"success|redirect\"}[$__range]))",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 4,
      "title": "Error in Range",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(polytope_broker_requests_finished_total{cluster=~\"$cluster\", namespace=~\"$namespace\", outcome=\"error\"}[$__range]))",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "fixedColor": "orange",
            "mode": "fixed"
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 5,
      "title": "Aborted in Range",
      "description": "Requests cancelled by client or lost (client_gone) in the dashboard time range.",
      "type": "stat",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(polytope_broker_requests_finished_total{cluster=~\"$cluster\", namespace=~\"$namespace\", outcome=~\"cancelled|client_gone\"}[$__range]))",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "fixedColor": "yellow",
            "mode": "fixed"
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 6,
      "title": "Avg Time to Request Availability",
      "type": "stat",
      "gridPos": {
        "x": 20,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(polytope_broker_request_duration_seconds_sum{cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__range])) / sum(rate(polytope_broker_request_duration_seconds_count{cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__range])) * 1000",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 10,
      "title": "Accepted Requests per Minute",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum(rate(polytope_broker_requests_accepted_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m])) * 60",
          "legendFormat": "accepted",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        }
      }
    },
    {
      "id": 11,
      "title": "Finished Request Outcomes per Minute",
      "type": "timeseries",
      "gridPos": {
        "x": 8,
        "y": 4,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum by (outcome)(rate(polytope_broker_requests_finished_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m])) * 60",
          "legendFormat": "{{outcome}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": {
            "fillOpacity": 45,
            "lineWidth": 1,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "drawStyle": "line"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "success"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "error"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "failed"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "overloaded"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "yellow",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        }
      }
    },
    {
      "id": 12,
      "title": "Time to Request Availability p50/p95/p99",
      "type": "timeseries",
      "gridPos": {
        "x": 16,
        "y": 4,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le)(rate(polytope_broker_request_duration_seconds_bucket{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "p50",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le)(rate(polytope_broker_request_duration_seconds_bucket{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "p95",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le)(rate(polytope_broker_request_duration_seconds_bucket{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "p99",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        }
      }
    },
    {
      "id": 15,
      "title": "Abort/Error Detail",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 16,
      "title": "Abort / Failure Rate per Minute",
      "description": "Rate of non-success outcomes: cancelled, client_gone, failed, error, overloaded.",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 16,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum by (outcome)(rate(polytope_broker_requests_finished_total{cluster=~\"$cluster\", namespace=~\"$namespace\", outcome=~\"cancelled|client_gone|failed|error|overloaded\"}[5m])) * 60",
          "legendFormat": "{{outcome}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 30,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "cancelled"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "yellow",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "client_gone"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "failed"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "error"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#8B0000",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "overloaded"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "purple",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean",
            "max"
          ]
        }
      }
    },
    {
      "id": 17,
      "title": "Error Rate %",
      "type": "timeseries",
      "gridPos": {
        "x": 16,
        "y": 12,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum(rate(polytope_broker_requests_finished_total{cluster=~\"$cluster\", namespace=~\"$namespace\", outcome=~\"error|failed\"}[5m])) / sum(rate(polytope_broker_requests_finished_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m])) * 100",
          "legendFormat": "error+failed %",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 5,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        }
      }
    },
    {
      "id": 20,
      "title": "Per-Broker Breakdown",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 19,
        "w": 24,
        "h": 1
      },
      "collapsed": true,
      "panels": [
        {
          "id": 21,
          "title": "Accepted Requests by Broker per Minute",
          "type": "timeseries",
          "gridPos": {
            "x": 0,
            "y": 20,
            "w": 6,
            "h": 8
          },
          "targets": [
            {
              "expr": "sum by (service_instance_id)(rate(polytope_broker_requests_accepted_total{cluster=~\"$cluster\", namespace=~\"$namespace\", service_instance_id=~\"$service_instance_id\"}[5m])) * 60",
              "legendFormat": "{{service_instance_id}}",
              "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
              }
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "reqpm",
              "custom": {
                "fillOpacity": 20,
                "lineWidth": 2,
                "stacking": {
                  "mode": "normal"
                }
              }
            },
            "overrides": []
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": [
                "lastNotNull",
                "mean"
              ]
            }
          }
        },
        {
          "id": 22,
          "title": "Success/Redirect % by Broker",
          "type": "timeseries",
          "gridPos": {
            "x": 6,
            "y": 20,
            "w": 6,
            "h": 8
          },
          "targets": [
            {
              "expr": "sum by (service_instance_id)(rate(polytope_broker_requests_finished_total{cluster=~\"$cluster\", namespace=~\"$namespace\", service_instance_id=~\"$service_instance_id\", outcome=~\"success|redirect\"}[5m])) / sum by (service_instance_id)(rate(polytope_broker_requests_finished_total{cluster=~\"$cluster\", namespace=~\"$namespace\", service_instance_id=~\"$service_instance_id\"}[5m])) * 100",
              "legendFormat": "{{service_instance_id}}",
              "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
              }
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "custom": {
                "lineWidth": 2,
                "fillOpacity": 10
              }
            },
            "overrides": []
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": [
                "lastNotNull",
                "mean"
              ]
            }
          }
        },
        {
          "id": 23,
          "title": "Latency by Broker",
          "type": "timeseries",
          "gridPos": {
            "x": 12,
            "y": 20,
            "w": 6,
            "h": 8
          },
          "targets": [
            {
              "expr": "histogram_quantile(0.50, sum by (le, service_instance_id)(rate(polytope_broker_request_duration_seconds_bucket{cluster=~\"$cluster\", namespace=~\"$namespace\", service_instance_id=~\"$service_instance_id\"}[5m])))",
              "legendFormat": "{{service_instance_id}} p50",
              "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
              }
            },
            {
              "expr": "histogram_quantile(0.95, sum by (le, service_instance_id)(rate(polytope_broker_request_duration_seconds_bucket{cluster=~\"$cluster\", namespace=~\"$namespace\", service_instance_id=~\"$service_instance_id\"}[5m])))",
              "legendFormat": "{{service_instance_id}} p95",
              "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
              }
            },
            {
              "expr": "histogram_quantile(0.99, sum by (le, service_instance_id)(rate(polytope_broker_request_duration_seconds_bucket{cluster=~\"$cluster\", namespace=~\"$namespace\", service_instance_id=~\"$service_instance_id\"}[5m])))",
              "legendFormat": "{{service_instance_id}} p99",
              "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
              }
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "s",
              "custom": {
                "lineWidth": 2,
                "fillOpacity": 10
              }
            },
            "overrides": []
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": [
                "lastNotNull",
                "mean"
              ]
            }
          }
        },
        {
          "id": 24,
          "title": "Finished by Outcome + Broker",
          "type": "timeseries",
          "gridPos": {
            "x": 18,
            "y": 20,
            "w": 6,
            "h": 8
          },
          "targets": [
            {
              "expr": "sum by (service_instance_id, outcome)(rate(polytope_broker_requests_finished_total{cluster=~\"$cluster\", namespace=~\"$namespace\", service_instance_id=~\"$service_instance_id\"}[5m])) * 60",
              "legendFormat": "{{service_instance_id}} \u2014 {{outcome}}",
              "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
              }
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "reqpm",
              "custom": {
                "fillOpacity": 45,
                "lineWidth": 1,
                "stacking": {
                  "mode": "normal",
                  "group": "A"
                },
                "drawStyle": "line"
              }
            },
            "overrides": []
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": [
                "lastNotNull",
                "mean"
              ]
            }
          }
        }
      ]
    },
    {
      "id": 30,
      "title": "Dispatcher",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 29,
        "w": 24,
        "h": 1
      },
      "collapsed": true,
      "panels": [
        {
          "id": 31,
          "title": "Queue Depth by Instance",
          "description": "Current number of jobs waiting in dispatch queues across all brokers",
          "type": "timeseries",
          "gridPos": {
            "x": 0,
            "y": 30,
            "w": 8,
            "h": 7
          },
          "targets": [
            {
              "expr": "polytope_broker_dispatcher_queue_depth{cluster=~\"$cluster\", namespace=~\"$namespace\"}",
              "legendFormat": "{{service_instance_id}}",
              "datasource": {
                "type": "prometheus",
