{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Datasource",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "uid": "polytope-overview",
  "title": "Polytope Overview",
  "description": "Single-page operator dashboard for Polytope request flow, throughput, and saturation.",
  "tags": [
    "polytope",
    "overview",
    "tier:top"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "graphTooltip": 1,
  "editable": true,
  "schemaVersion": 39,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "links": [
    {
      "title": "Broker & Dispatcher",
      "type": "link",
      "icon": "external link",
      "url": "/d/polytope-broker-dispatcher-merged/polytope-broker-and-dispatcher?${__url_time_range}&${__all_variables}",
      "targetBlank": false
    },
    {
      "title": "Workers",
      "type": "link",
      "icon": "external link",
      "url": "/d/polytope-worker-metrics/polytope-worker-metrics?${__url_time_range}&${__all_variables}",
      "targetBlank": false
    },
    {
      "title": "BOBS Storage",
      "type": "link",
      "icon": "external link",
      "url": "/d/bobs-spool-metrics/polytope-bobs-storage?${__url_time_range}&${__all_variables}",
      "targetBlank": false
    },
    {
      "title": "Raw Metrics (Debug)",
      "type": "link",
      "icon": "bolt",
      "url": "/d/polytope-raw-metrics/polytope-raw-metrics-debug?${__url_time_range}&${__all_variables}",
      "targetBlank": false
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "label": "Datasource",
        "current": {
          "selected": true,
          "text": "Thanos CCI1",
          "value": "Thanos CCI1"
        },
        "hide": 0
      },
      {
        "name": "cluster",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(polytope_broker_requests_accepted_total, cluster)",
        "label": "Cluster",
        "hide": 0,
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "sort": 1,
        "current": {}
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(polytope_broker_requests_accepted_total{cluster=~\"$cluster\"}, namespace)",
        "label": "Namespace",
        "hide": 0,
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "sort": 1,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Requests Accepted / min",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(polytope_broker_requests_accepted_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m])) * 60",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 2,
      "title": "Success Rate %",
      "type": "stat",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(polytope_broker_requests_finished_total{cluster=~\"$cluster\", namespace=~\"$namespace\", outcome=~\"success|redirect\"}[5m])) / sum(rate(polytope_broker_requests_finished_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m])) * 100",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 80,
                "color": "yellow"
              },
              {
                "value": 95,
                "color": "green"
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 3,
      "title": "Active Worker Jobs",
      "type": "stat",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(polytope_worker_jobs_active{cluster=~\"$cluster\", namespace=~\"$namespace\"})",
          "legendFormat": "active",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "orientation": "auto"
      }
    },
    {
      "id": 4,
      "title": "Avg Time to Request Availability",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(polytope_broker_request_duration_seconds_sum{cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__range])) / sum(rate(polytope_broker_request_duration_seconds_count{cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__range])) * 1000",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 5,
      "title": "Bytes Delivered",
      "type": "stat",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(polytope_worker_delivery_bytes_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__range]))",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 6,
      "title": "Queue Depth",
      "type": "stat",
      "gridPos": {
        "x": 20,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(polytope_broker_dispatcher_queue_depth{cluster=~\"$cluster\", namespace=~\"$namespace\"})",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1000,
                "color": "yellow"
              },
              {
                "value": 10000,
                "color": "red"
              }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 10,
      "title": "Accepted vs Finished Rate",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(polytope_broker_requests_accepted_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m])) * 60",
          "legendFormat": "accepted",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "sum(rate(polytope_broker_requests_finished_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m])) * 60",
          "legendFormat": "finished",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        }
      }
    },
    {
      "id": 11,
      "title": "Outcome Breakdown",
      "type": "timeseries",
      "gridPos": {
        "x": 8,
        "y": 4,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (outcome)(rate(polytope_broker_requests_finished_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m])) * 60",
          "legendFormat": "{{outcome}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": {
            "fillOpacity": 45,
            "lineWidth": 1,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "drawStyle": "line",
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "success"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "redirect"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#73BF69",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "error"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "failed"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "overloaded"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "yellow",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "cancelled"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#B877D9",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "client_gone"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#FF9830",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        }
      }
    },
    {
      "id": 12,
      "title": "Time to Request Availability p50/p95/p99",
      "type": "timeseries",
      "gridPos": {
        "x": 16,
        "y": 4,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le)(rate(polytope_broker_request_duration_seconds_bucket{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "p50",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le)(rate(polytope_broker_request_duration_seconds_bucket{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "p95",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le)(rate(polytope_broker_request_duration_seconds_bucket{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "p99",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        }
      }
    },
    {
      "id": 20,
      "title": "Broker vs BOBS Completions / min",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(rate(polytope_broker_requests_finished_total{cluster=~\"$cluster\", namespace=~\"$namespace\", outcome=~\"success|redirect\"}[5m])) * 60",
          "legendFormat": "broker finished",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (outcome)(rate(bobs_read_duration_seconds_count{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m])) * 60",
          "legendFormat": "BOBS {{outcome}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never",
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "BOBS error"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "BOBS success"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#73BF69",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        }
      },
      "description": "Broker requests finished successfully vs BOBS reads completed. A growing gap means clients are not finishing their downloads."
    },
    {
      "id": 21,
      "title": "Dispatcher Queue Depth",
      "type": "timeseries",
      "gridPos": {
        "x": 8,
        "y": 12,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "polytope_broker_dispatcher_queue_depth{cluster=~\"$cluster\", namespace=~\"$namespace\"}",
          "legendFormat": "{{service_instance_id}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "stacking": {
              "mode": "normal"
            },
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1000,
                "color": "yellow"
              },
              {
                "value": 10000,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        }
      }
    },
    {
      "id": 22,
      "title": "Queue Wait p50/p95/p99",
      "type": "timeseries",
      "gridPos": {
        "x": 16,
        "y": 12,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(polytope_broker_dispatcher_queue_wait_seconds_bucket{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m])) by (le))",
          "legendFormat": "p50",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(polytope_broker_dispatcher_queue_wait_seconds_bucket{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m])) by (le))",
          "legendFormat": "p95",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(polytope_broker_dispatcher_queue_wait_seconds_bucket{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m])) by (le))",
          "legendFormat": "p99",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        }
      }
    },
    {
      "id": 30,
      "title": "By Collection",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 24,
        "h": 1
      },
      "collapsed": true,
      "panels": [
        {
          "id": 31,
          "title": "Request Rate by Collection",
          "type": "timeseries",
          "gridPos": {
            "x": 0,
            "y": 21,
            "w": 6,
            "h": 8
          },
          "targets": [
            {
              "expr": "sum by (route_handle)(rate(polytope_broker_collection_requests_accepted_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m])) * 60",
              "legendFormat": "{{route_handle}}",
              "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
              }
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "reqpm",
              "custom": {
                "lineWidth": 2,
                "fillOpacity": 10,
                "showPoints": "never"
              }
            },
            "overrides": []
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": [
                "lastNotNull",
                "mean"
              ]
            }
          }
        },
        {
          "id": 32,
          "title": "Success % by Collection",
          "type": "bargauge",
          "gridPos": {
            "x": 6,
            "y": 21,
            "w": 6,
            "h": 8
          },
          "targets": [
            {
              "expr": "sum by (route_handle)(rate(polytope_broker_collection_requests_finished_total{cluster=~\"$cluster\", namespace=~\"$namespace\", outcome=~\"success|redirect\"}[5m])) / sum by (route_handle)(rate(polytope_broker_collection_requests_finished_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m])) * 100",
              "legendFormat": "{{route_handle}}",
              "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
              }
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {
                    "value": null,
                    "color": "red"
                  },
                  {
                    "value": 80,
                    "color": "yellow"
                  },
                  {
                    "value": 95,
                    "color": "green"
                  }
                ]
              }
            },
            "overrides": []
          },
          "options": {
            "orientation": "horizontal",
            "displayMode": "gradient"
          }
        },
        {
          "id": 33,
          "title": "Collection Latency p50/p95",
          "type": "timeseries",
          "gridPos": {
            "x": 12,
            "y": 21,
            "w": 6,
            "h": 8
          },
          "targets": [
            {
              "expr": "histogram_quantile(0.50, sum by (le, route_handle)(rate(polytope_broker_collection_request_duration_seconds_bucket{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m])))",
              "legendFormat": "{{route_handle}} p50",
              "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
              }
            },
            {
