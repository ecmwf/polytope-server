{
  "title": "BOBS Spool Metrics",
  "tags": ["polytope", "bobs"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Download Throughput (bytes/sec)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "sum(rate(bobs_read_bytes_total[5m]))",
          "legendFormat": "total",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        },
        {
          "expr": "sum by (collection)(rate(bobs_read_bytes_total[5m]))",
          "legendFormat": "{{collection}}",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps", "custom": { "fillOpacity": 20, "lineWidth": 2 } }
      }
    },
    {
      "id": 2,
      "title": "Active Readers",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "sum(bobs_read_active)",
          "legendFormat": "total",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        },
        {
          "expr": "sum by (collection)(bobs_read_active)",
          "legendFormat": "{{collection}}",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 20, "lineWidth": 2 } }
      }
    },
    {
      "id": 3,
      "title": "Read Duration (p50/p95/p99)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 7, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le)(rate(bobs_read_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le)(rate(bobs_read_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le)(rate(bobs_read_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10, "lineWidth": 2 } }
      }
    },
    {
      "id": 4,
      "title": "Write Throughput (bytes/sec)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 7, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "sum(rate(bobs_write_bytes_total[5m]))",
          "legendFormat": "total",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        },
        {
          "expr": "sum by (collection)(rate(bobs_write_bytes_total[5m]))",
          "legendFormat": "{{collection}}",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps", "custom": { "fillOpacity": 20, "lineWidth": 2 } }
      }
    },
    {
      "id": 5,
      "title": "Spool Lifecycle",
      "type": "row",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 6,
      "title": "Active Spools by State",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 15, "w": 8, "h": 7 },
      "targets": [
        {
          "expr": "sum by (state)(bobs_spools_active)",
          "legendFormat": "{{state}}",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 30, "lineWidth": 2, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "id": 7,
      "title": "Spools Created/Completed/Deleted (rate/min)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 15, "w": 8, "h": 7 },
      "targets": [
        {
          "expr": "sum(rate(bobs_spools_created_total[5m])) * 60",
          "legendFormat": "created",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        },
        {
          "expr": "sum(rate(bobs_spools_completed_total[5m])) * 60",
          "legendFormat": "completed",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        },
        {
          "expr": "sum(rate(bobs_spools_deleted_total[5m])) * 60",
          "legendFormat": "deleted",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 20, "lineWidth": 2 } }
      }
    },
    {
      "id": 8,
      "title": "Deletions by Reason (rate/min)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 15, "w": 8, "h": 7 },
      "targets": [
        {
          "expr": "sum by (reason)(rate(bobs_spools_deleted_total[5m])) * 60",
          "legendFormat": "{{reason}}",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 30, "lineWidth": 2, "stacking": { "mode": "normal" } } }
      }
    },
    {
      "id": 9,
      "title": "System",
      "type": "row",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 10,
      "title": "Disk Usage",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 23, "w": 8, "h": 7 },
      "targets": [
        {
          "expr": "sum by (service_instance_id)(bobs_disk_usage_bytes)",
          "legendFormat": "{{service_instance_id}}",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "fillOpacity": 20, "lineWidth": 2 } }
      }
    },
    {
      "id": 11,
      "title": "Page Cache Hit Rate (%)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 23, "w": 8, "h": 7 },
      "targets": [
        {
          "expr": "sum(rate(bobs_pages_cache_hits_total[5m])) / (sum(rate(bobs_pages_cache_hits_total[5m])) + sum(rate(bobs_pages_cache_misses_total[5m]))) * 100",
          "legendFormat": "hit rate",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "thresholds": {
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 50, "color": "orange" },
              { "value": 80, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "title": "Per-Collection Download (bytes/sec)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 23, "w": 8, "h": 7 },
      "targets": [
        {
          "expr": "sum by (collection)(rate(bobs_read_bytes_total{collection!=\"\"}[5m]))",
          "legendFormat": "{{collection}}",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps", "custom": { "fillOpacity": 30, "lineWidth": 2, "stacking": { "mode": "normal" } } }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      }
    ]
  }
}
