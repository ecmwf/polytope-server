{
  "uid": "bobs-spool-metrics",
  "title": "Polytope BOBS Storage",
  "tags": ["polytope", "bobs", "tier:drilldown"],
  "description": "BOBS spool read/write throughput, lifecycle, and system metrics.",
  "links": [
    {
      "title": "← Overview",
      "type": "link",
      "icon": "arrow-left",
      "url": "/d/polytope-overview/polytope-overview?${__url_time_range}&var-DS_PROMETHEUS=${DS_PROMETHEUS}&var-cluster=${cluster}&var-namespace=${namespace}",
      "targetBlank": false
    }
  ],
  "graphTooltip": 1,
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 2,
      "title": "Read Ops/s by Collection",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum by (collection)(rate(bobs_read_duration_seconds_count{cluster=~\"$cluster\", namespace=~\"$namespace\", outcome=\"success\", collection!=\"\"}[$__rate_interval]))",
          "legendFormat": "{{collection}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        }
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Write Ops/s by Collection",
      "gridPos": {
        "x": 12,
        "y": 7,
        "w": 12,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (collection)(rate(bobs_write_duration_seconds_count{cluster=~\"$cluster\", namespace=~\"$namespace\", outcome=\"success\", collection!=\"\"}[$__rate_interval]))",
          "legendFormat": "{{collection}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        }
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Read Duration Quantiles",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 12,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le)(rate(bobs_read_duration_seconds_bucket{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "p50",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le)(rate(bobs_read_duration_seconds_bucket{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "p95",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le)(rate(bobs_read_duration_seconds_bucket{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "p99",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        }
      }
    },
    {
      "id": 3,
      "title": "Write Duration Quantiles",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 14,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le)(rate(bobs_write_duration_seconds_bucket{cluster=~\"$cluster\", namespace=~\"$namespace\", outcome=\"success\"}[$__rate_interval])))",
          "legendFormat": "p50",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le)(rate(bobs_write_duration_seconds_bucket{cluster=~\"$cluster\", namespace=~\"$namespace\", outcome=\"success\"}[$__rate_interval])))",
          "legendFormat": "p95",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le)(rate(bobs_write_duration_seconds_bucket{cluster=~\"$cluster\", namespace=~\"$namespace\", outcome=\"success\"}[$__rate_interval])))",
          "legendFormat": "p99",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        }
      }
    },
    {
      "id": 4,
      "title": "Write Throughput by Collection",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum by (collection)(rate(bobs_write_bytes_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "{{collection}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Spool Lifecycle",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 6,
      "title": "Active Spools by State",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum by (state)(bobs_spools_active{cluster=~\"$cluster\", namespace=~\"$namespace\"})",
          "legendFormat": "{{state}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 30,
            "lineWidth": 2,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Spool Lifecycle Events/min",
      "type": "timeseries",
      "gridPos": {
        "x": 8,
        "y": 22,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum(rate(bobs_spools_created_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m])) * 60",
          "legendFormat": "created",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "sum(rate(bobs_spools_completed_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m])) * 60",
          "legendFormat": "completed",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "sum(rate(bobs_spools_deleted_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m])) * 60",
          "legendFormat": "deleted",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Spool Deletions by Reason/min",
      "type": "timeseries",
      "gridPos": {
        "x": 16,
        "y": 22,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum by (reason)(rate(bobs_spools_deleted_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m])) * 60",
          "legendFormat": "{{reason}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 30,
            "lineWidth": 2,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      }
    },
    {
      "id": 9,
      "title": "System",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 29,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 10,
      "title": "Disk Usage by Instance",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 30,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum by (service_instance_id)(bobs_disk_usage_bytes{cluster=~\"$cluster\", namespace=~\"$namespace\"})",
          "legendFormat": "{{service_instance_id}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      }
    },
    {
      "id": 11,
      "title": "Page Cache Hit Ratio, Lifetime",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 30,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum(bobs_pages_cache_hits_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}) / (sum(bobs_pages_cache_hits_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}) + (sum(bobs_pages_cache_misses_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}) or vector(0))) * 100",
          "legendFormat": "hit rate",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "stacking": {
              "mode": "normal"
            }
          },
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 50,
                "color": "orange"
              },
              {
                "value": 80,
                "color": "green"
              }
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "title": "Read Throughput by Collection",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum by (collection)(rate(bobs_read_bytes_total{cluster=~\"$cluster\", namespace=~\"$namespace\", collection!=\"\"}[5m]))",
          "legendFormat": "{{collection}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "fillOpacity": 30,
            "lineWidth": 2,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "label": "Datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": true,
          "text": "Thanos CCI1",
          "value": "Thanos CCI1"
        },
        "hide": 0
      },
      {
        "name": "cluster",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(bobs_spools_active, cluster)",
        "label": "Cluster",
        "hide": 0,
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "sort": 1,
        "current": {}
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(bobs_spools_active{cluster=~\"$cluster\"}, namespace)",
        "label": "Namespace",
        "hide": 0,
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "sort": 1,
        "current": {}
      }
    ]
  },
  "version": 4
}
