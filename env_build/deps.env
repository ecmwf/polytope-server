# Non-secret source-build dependency pins shared by Docker/Skaffold and
# local env_build/build.sh runs.
#
# Override any value by exporting it before sourcing this file, e.g.
#   ECCODES_VERSION=2.47.0 env_build/build.sh

: "${PYTHON_VERSION:=3.11}"
: "${ECBUILD_VERSION:=3.14.0}"
: "${LIBAEC_VERSION:=v1.1.4}"
: "${ECKIT_VERSION:=1.33.2}"
: "${ECCODES_VERSION:=2.46.0}"
: "${METKIT_VERSION:=1.18.1}"
: "${FDB_VERSION:=5.21.3}"
: "${GRIBJUMP_VERSION:=0.12.0}"
: "${MARS_CLIENT_C_BUNDLE_REF:=develop}"
: "${MARS_CLIENT_CPP_BUNDLE_REF:=develop-cpp}"
