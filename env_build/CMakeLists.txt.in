
cmake_minimum_required( VERSION 3.12 FATAL_ERROR )
find_package( ecbuild 3.7.2 REQUIRED HINTS ${CMAKE_CURRENT_SOURCE_DIR} ${CMAKE_CURRENT_SOURCE_DIR}/../ecbuild)

project( GJBundle VERSION 0.10.4 LANGUAGES C CXX )

set(CMAKE_CXX_STANDARD 17)
set(CMAKE_CXX_STANDARD_REQUIRED ON)
set(CMAKE_CXX_FLAGS "-Wall -Wextra -Wno-unused-parameter -Wno-unused-variable -Wno-reorder -Wno-sign-compare")

ecbuild_bundle_initialize()

ecbuild_bundle( PROJECT eckit           GIT "https://github.com/ecmwf/eckit"                 TAG 1.33.2   UPDATE) # final eckit version pre V2
ecbuild_bundle( PROJECT eccodes         GIT "https://github.com/ecmwf/eccodes"               TAG 2.46.1   UPDATE)
ecbuild_bundle( PROJECT metkit          GIT "https://github.com/ecmwf/metkit"                TAG 1.17.2   UPDATE)
ecbuild_bundle( PROJECT fdb5            GIT "https://github.com/ecmwf/fdb"                   BRANCH fix/pyfdb-array-size UPDATE)
ecbuild_bundle( PROJECT gribjump        GIT "https://github.com/ecmwf/gribjump"              BRANCH feature/GJ-63-sub-hourly UPDATE)

ecbuild_bundle_finalize()