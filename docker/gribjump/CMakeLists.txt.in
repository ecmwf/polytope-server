
cmake_minimum_required( VERSION 3.12 FATAL_ERROR )
find_package( ecbuild 3.7.2 REQUIRED HINTS ${CMAKE_CURRENT_SOURCE_DIR} ${CMAKE_CURRENT_SOURCE_DIR}/../ecbuild)

foreach(DEPENDENCY ECKIT ECCODES METKIT FDB GRIBJUMP)
    set(VERSION_VAR "${DEPENDENCY}_VERSION")
    if("$ENV{${VERSION_VAR}}" STREQUAL "")
        message(FATAL_ERROR "${VERSION_VAR} must be set")
    endif()
    set(${VERSION_VAR} "$ENV{${VERSION_VAR}}")
endforeach()

project( GJBundle VERSION ${GRIBJUMP_VERSION} LANGUAGES C CXX )

set(CMAKE_CXX_STANDARD 17)
set(CMAKE_CXX_STANDARD_REQUIRED ON)
set(CMAKE_CXX_FLAGS "-Wall -Wextra -Wno-unused-parameter -Wno-unused-variable -Wno-reorder -Wno-sign-compare")

ecbuild_bundle_initialize()

set(ENABLE_BUILD_TOOLS OFF CACHE BOOL "Disable bundle command-line tools" FORCE)
set(ENABLE_FDB_BUILD_TOOLS OFF CACHE BOOL "Disable FDB command-line tools" FORCE)
set(ENABLE_TESTS OFF CACHE BOOL "Disable bundle tests" FORCE)

ecbuild_bundle( PROJECT eckit           GIT "https://github.com/ecmwf/eckit"                 TAG ${ECKIT_VERSION}   UPDATE) # final eckit version pre V2
ecbuild_bundle( PROJECT eccodes         GIT "https://github.com/ecmwf/eccodes"               TAG ${ECCODES_VERSION}   UPDATE)
ecbuild_bundle( PROJECT metkit          GIT "https://github.com/ecmwf/metkit"                TAG ${METKIT_VERSION}   UPDATE)
ecbuild_bundle( PROJECT fdb5            GIT "https://github.com/ecmwf/fdb"                   TAG ${FDB_VERSION}   UPDATE)
ecbuild_bundle( PROJECT gribjump        GIT "https://github.com/ecmwf/gribjump"              TAG ${GRIBJUMP_VERSION}   UPDATE)

ecbuild_bundle_finalize()
